    {
      "parameters": {
        "jsCode": "const source = ($json.body && typeof $json.body === 'object') ? $json.body : $json;\nreturn [{\n  json: {\n    run_id: String(source.run_id || '').trim(),\n    decision: String(source.decision || '').trim(),\n    reviewer_notes: String(source.reviewer_notes || '').trim(),\n    final_markdown_edited: String(source.final_markdown_edited || ''),\n  }\n}];"
      },
      "id": "7096acb3-b31f-4acb-8d7c-fbcda28c4e75",
      "name": "Normalize Review Action Request",
      "type": "n8n-nodes-base.code",
      "position": [
        -2288,
        560
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "let base = {};\ntry { base = $('Apply Approval Decision').first().json; } catch {}\n\nlet telegram_result = null;\ntry { telegram_result = $('Send Telegram Message - Configure Credential').first().json.result || null; } catch {}\n\nreturn [{\n  json: {\n    ok: true,\n    run_id: base.run_id || '',\n    status: base.status || '',\n    reviewer_notes: base.reviewer_notes || '',\n    notified: Boolean(base.notify_allowed),\n    telegram_result,\n    message: base.notify_allowed\n      ? 'Review action completed. Telegram sent and approval stored.'\n      : 'Review action completed. Notification skipped.'\n  }\n}];"
      },
      "id": "b7371bf0-f26e-4b67-ac3c-ba2d0e12ee46",
      "name": "Build Review Action Response",
      "type": "n8n-nodes-base.code",
      "position": [
        304,
        512
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst approvedText = String(item.final_markdown_approved || '').trim();\nconst meetingTitle = String(item.meeting_title || 'Approved follow-up').trim();\nconst reviewerName = String(item.reviewer_name || 'Reviewer').trim();\nconst languageHint = String(item.language_hint || item.meeting_json?.language_hint || '').trim();\n\nconst czechSignalText = `${languageHint} ${meetingTitle} ${reviewerName} ${approvedText.slice(0, 1600)}`;\nconst hasCzechDiacritics = /[\\u011b\\u0161\\u010d\\u0159\\u017e\\u00fd\\u00e1\\u00ed\\u00e9\\u00fa\\u016f\\u010f\\u0165\\u0148\\u00f3\\u011a\\u0160\\u010c\\u0158\\u017d\\u00dd\\u00c1\\u00cd\\u00c9\\u00da\\u016e\\u010e\\u0164\\u0147\\u00d3]/.test(czechSignalText);\nconst hasCzechSections = /(^|\\n)#{0,2}\\s*(Shrnuti|Hlavni ukoly|Klicova rozhodnuti|Rizika a otevrene otazky|FAQ)\\b/i.test(czechSignalText.normalize('NFD').replace(/[\\u0300-\\u036f]/g, ''));\nconst isCzech = /czech|čeština|cestina|cz|cs/i.test(languageHint) || hasCzechDiacritics || hasCzechSections;\n\nconst prompt = isCzech\n  ? `Převeď schválený follow-up do krátké Telegram zprávy.\n\nVrať validní JSON pouze v tomto tvaru:\n{\"message\":\"...\"}\n\nPoužij přesně tuto strukturu zprávy:\n\n${meetingTitle} - SCHVÁLENO\n\nShrnutí:\n- ...\n- ...\n- ...\n\nÚkoly:\n1. Vlastník: úkol\n2. Vlastník: úkol\n3. Vlastník: úkol\n\nOtevřené otázky:\n- ...\n- ...\n\nSchválil/a: ${reviewerName}\n\nPravidla:\n- Nepoužívej emoji.\n- Nepoužívej markdown tabulky.\n- Nepoužívej HTML.\n- Nepřidávej hashtagy.\n- Nepřidávej úvod ani závěr mimo šablonu.\n- Maximálně 3 body ve Shrnutí.\n- Maximálně 5 úkolů.\n- Maximálně 3 otevřené otázky.\n- Nevymýšlej vlastníky, termíny, rozhodnutí ani rizika.\n- Pokud vlastník není jasný, napiš \"Vlastník nejasný\".\n- Pokud nejsou jasné úkoly, napiš \"Žádné jasné úkoly.\"\n- Pokud nejsou otevřené otázky, napiš \"Žádné otevřené otázky.\"\n- Celá zpráva musí být pod 1800 znaků.\n- Piš česky.\n- Nepřekládej obsah do angličtiny.\n\nSchválený follow-up text:\n${approvedText}`\n  : `Convert the approved follow-up into a short Telegram message.\n\nReturn valid JSON only in this shape:\n{\"message\":\"...\"}\n\nUse exactly this message structure:\n\n${meetingTitle} - APPROVED\n\nSummary:\n- ...\n- ...\n- ...\n\nActions:\n1. Owner: action\n2. Owner: action\n3. Owner: action\n\nOpen questions:\n- ...\n- ...\n\nReviewed by: ${reviewerName}\n\nRules:\n- No emojis.\n- No markdown tables.\n- No HTML.\n- No hashtags.\n- No intro or outro outside the template.\n- Maximum 3 Summary bullets.\n- Maximum 5 Actions.\n- Maximum 3 Open questions.\n- Do not invent owners, deadlines, decisions, or risks.\n- If owner is unclear, write \"Owner unclear\".\n- If there are no clear actions, write \"No clear action items.\"\n- If there are no open questions, write \"No open questions captured.\"\n- Keep the whole message under 1800 characters.\n- Write in English.\n- If the approved follow-up text is clearly Czech, use the Czech template instead.\n\nApproved follow-up text:\n${approvedText}`;\n\nreturn [{\n  json: {\n    ...item,\n    language_hint: languageHint,\n    telegram_summary_language: isCzech ? 'cs' : 'en',\n    telegram_summary_prompt: prompt,\n    telegram_minimax_body: {\n      model: 'MiniMax-M2.7',\n      messages: [\n        {\n          role: 'system',\n          content: 'Return valid JSON only. Follow the requested template exactly. Do not invent facts.'\n        },\n        {\n          role: 'user',\n          content: prompt\n        }\n      ],\n      temperature: 0.2\n    }\n  }\n}];\n"
      },
      "id": "29f54472-c2a5-49da-9df7-77dc94e18264",
      "name": "Build Telegram Summary Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -848,
        352
      ],
      "notesInFlow": true,
      "notes": "Formats a short Telegram-friendly message. Bind the Telegram node after import."
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst meta = $('Build Telegram Summary Prompt').first().json;\n\nconst raw =\n  response.choices?.[0]?.message?.content ??\n  response.body?.choices?.[0]?.message?.content ??\n  response.data?.choices?.[0]?.message?.content ??\n  '';\n\nconst isCzech = String(meta.telegram_summary_language || '').toLowerCase() === 'cs';\n\nconst fallbackMessage = isCzech\n  ? `Schválený follow-up je připraven\\n\\nSetkání: ${meta.meeting_title || ''}\\nStatus: ${meta.status || ''}\\nSchvalovatel: ${meta.reviewer_name || ''}`\n  : `Approved follow-up ready\\n\\nMeeting: ${meta.meeting_title || ''}\\nStatus: ${meta.status || ''}\\nReviewer: ${meta.reviewer_name || ''}`;\n\nif (!raw || typeof raw !== 'string') {\n  return [{\n    json: {\n      ...meta,\n      message: fallbackMessage\n    }\n  }];\n}\n\nlet cleaned = raw\n  .replace(/<think>[\\s\\S]*?<\\/think>\\s*/g, '')\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst firstBrace = cleaned.indexOf('{');\nconst lastBrace = cleaned.lastIndexOf('}');\nif (firstBrace >= 0 && lastBrace > firstBrace) {\n  cleaned = cleaned.slice(firstBrace, lastBrace + 1);\n}\n\ntry {\n  const parsed = JSON.parse(cleaned);\n  const message = String(parsed.message || '').trim();\n\n  return [{\n    json: {\n      ...meta,\n      message: message || fallbackMessage\n    }\n  }];\n} catch {\n  return [{\n    json: {\n      ...meta,\n      message: fallbackMessage\n    }\n  }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
