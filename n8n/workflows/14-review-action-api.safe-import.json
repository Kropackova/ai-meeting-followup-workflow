      "notes": "Bind your Google Sheets credential. For local/private n8n, Google Service Account is the practical default. Configure lookup to return every row matching run_id if your n8n version offers that option, then guard against duplicates."
    },
    {
      "parameters": {
        "jsCode": "const request = $('Validate Approval Request').first().json;\nconst rows = $input.all().map((item) => item.json).filter((row) => String(row.run_id || '').trim() === request.run_id);\nlet guard_error = '';\nlet row = rows[0] || {};\n\nif (rows.length !== 1) {\n  guard_error = rows.length === 0 ? 'No row found for run_id.' : 'Duplicate run_id rows found; stop without update.';\n} else if (row.status !== 'draft') {\n  guard_error = `Row status must be draft, got ${row.status || 'blank'}.`;\n}\n\nconst requestedEdited = String(request.final_markdown_edited || '').trim();\nconst effectiveEdited = requestedEdited || String(row.final_markdown_edited || '').trim();\n\nif (!guard_error && request.decision === 'approve_with_sheet_edits' && !effectiveEdited) {\n  guard_error = 'approve_with_sheet_edits requires final_markdown_edited.';\n}\n\nreturn [{ json: { ...row, ...request, final_markdown_edited: effectiveEdited, approval_ok: !guard_error, guard_error } }];"
      },
