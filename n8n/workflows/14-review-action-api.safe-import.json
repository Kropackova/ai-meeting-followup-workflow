      "parameters": {
        "jsCode": "const item = $input.first().json;\nlet status = item.status;\nlet final_markdown_approved = item.final_markdown_approved || '';\nlet notify_allowed = false;\nif (item.decision === 'reject') { status = 'rejected'; final_markdown_approved = ''; }\nif (item.decision === 'approve') { status = 'approved'; final_markdown_approved = item.final_markdown_draft || ''; notify_allowed = true; }\nif (item.decision === 'approve_with_sheet_edits') { status = 'approved_edited'; final_markdown_approved = item.final_markdown_edited || ''; notify_allowed = true; }\nif (String(item.notify_channel || 'none') === 'none') { notify_allowed = false; }\nreturn [{ json: { ...item, status, reviewer_notes: item.reviewer_notes || '', final_markdown_approved, notify_allowed, error_message: '' } }];"
      },
